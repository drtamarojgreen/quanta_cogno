{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quanta Cogno Application Configuration",
  "type": "object",
  "properties": {
    "app_name": { "type": "string" },
    "version": { "type": "string" },
    "persistence": {
      "type": "object",
      "properties": {
        "state_file": { "type": "string" },
        "cache_dir": { "type": "string" },
        "autosave_interval_ms": { "type": "integer" }
      }
    },
    "default_config": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "max_tokens": { "type": "integer" },
        "top_p": { "type": "number" },
        "repeat_penalty": { "type": "number" }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "alias": { "type": "string" },
          "requires_args": { "type": "boolean" }
        }
      }
    }
  }
}
